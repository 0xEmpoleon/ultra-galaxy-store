{
    "brand": "David AI",
    "version": "1.0.0",
    "meta": {
        "description": "Intellectual Minimalist aesthetic focusing on natural audio interaction.",
        "url": "https://www.withdavid.ai/"
    },
    "colors": {
        "background": {
            "primary": "#f9f9f6",
            "alternate": "#1a1a19",
            "off-white": "#f1f2ea",
            "blue-light": "#d9e5ff"
        },
        "text": {
            "primary": "#1a1a19",
            "secondary": "#82837c",
            "alternate": "#ffffff",
            "accent": "#2d62ff"
        },
        "accent": {
            "blue": "#2d62ff",
            "pink": "#dd23bb"
        },
        "border": {
            "default": "#cfd0c8",
            "dark": "#1a1a19"
        }
    },
    "typography": {
        "primary": "Inter, sans-serif",
        "secondary": "Besley, Times, serif",
        "mono": "Source Code Pro, monospace",
        "scale": {
            "h1": "4rem",
            "h2": "2.5rem",
            "h3": "1.75rem",
            "body": "1rem",
            "small": "0.875rem"
        }
    },
    "spacing": {
        "unit": "4px",
        "scale": {
            "xs": "4px",
            "sm": "8px",
            "md": "16px",
            "lg": "32px",
            "xl": "64px"
        }
    },
    "buttons": {
        "radius": "100px",
        "padding": "12px 32px"
    }
}
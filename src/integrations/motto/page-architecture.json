{
    "layout": {
        "maxWidth": "1440px",
        "gridColumns": 12,
        "gutter": "40px",
        "sectionPadding": "clamp(60px, 8vw, 160px) clamp(20px, 4vw, 80px)"
    },
    "breakpoints": {
        "desktop": "1200px",
        "tablet": "768px",
        "mobile": "480px"
    },
    "sections": [
        {
            "name": "Navigation",
            "tag": "nav",
            "layout": "flex",
            "position": "fixed",
            "children": [
                "logo",
                "links",
                "cta"
            ]
        },
        {
            "name": "Hero",
            "tag": "header",
            "layout": "flex column",
            "height": "100vh",
            "background": "var(--color-bg-primary)",
            "children": [
                "title",
                "subtitle",
                "stats-grid"
            ]
        },
        {
            "name": "Client Grid",
            "tag": "main",
            "layout": "grid",
            "columns": "repeat(auto-fill, minmax(300px, 1fr))",
            "gap": "1px",
            "background": "var(--color-border-default)",
            "children": [
                "client-card",
                "client-card",
                "client-card"
            ]
        },
        {
            "name": "Footer",
            "tag": "footer",
            "layout": "grid",
            "background": "var(--color-text-primary)",
            "color": "var(--color-bg-primary)",
            "children": [
                "giant-text",
                "links"
            ]
        }
    ],
    "components": {
        "client-card": {
            "structure": [
                "logo",
                "hover-reveal-image",
                "industry-tag"
            ],
            "aspectRatio": "1/1",
            "hoverEffect": "transform scale and overlay reveal"
        },
        "button": {
            "variants": [
                "primary",
                "ghost"
            ],
            "borderRadius": "var(--radii-pill)",
            "padding": "16px 32px"
        }
    }
}
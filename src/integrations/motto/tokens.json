{
    "color": {
        "brand": {
            "primary": "#000000",
            "secondary": "#FFFFFF",
            "accent": "#DBFF00"
        },
        "bg": {
            "primary": "#F2F2F2",
            "secondary": "#FFFFFF",
            "tertiary": "#1B1B1C"
        },
        "text": {
            "primary": "#000000",
            "secondary": "#1B1B1C",
            "inverted": "#FFFFFF",
            "accent": "#DBFF00"
        },
        "border": {
            "default": "rgba(0, 0, 0, 0.1)",
            "strong": "#000000"
        }
    },
    "typography": {
        "font": {
            "primary": "'PP Neue Montreal', 'Inter', sans-serif",
            "display": "'NON Natural Grotesk', 'Impact', sans-serif",
            "mono": "ui-monospace, Consolas, monospace"
        },
        "weight": {
            "regular": "400",
            "medium": "500",
            "semibold": "600",
            "bold": "700"
        },
        "scale": {
            "xs": "0.875rem",
            "sm": "1rem",
            "base": "clamp(1rem, 1.2vw, 1.25rem)",
            "lg": "1.5rem",
            "h3": "clamp(1.75rem, 2vw, 2.5rem)",
            "h2": "clamp(2.5rem, 3.5vw, 5rem)",
            "h1": "clamp(3.5rem, 5vw, 6.4rem)",
            "display": "clamp(5rem, 8vw, 10rem)"
        },
        "lineHeight": {
            "tight": "1",
            "snug": "1.1",
            "base": "1.35",
            "relaxed": "1.5"
        }
    },
    "spacing": {
        "base": "4px",
        "xs": "8px",
        "sm": "16px",
        "md": "24px",
        "lg": "32px",
        "xl": "64px",
        "2xl": "120px",
        "3xl": "240px"
    },
    "radii": {
        "none": "0px",
        "sm": "4px",
        "md": "8px",
        "pill": "9999px",
        "circle": "50%"
    },
    "effects": {
        "transition": {
            "fast": "0.2s cubic-bezier(0.165, 0.84, 0.44, 1)",
            "standard": "0.4s cubic-bezier(0.165, 0.84, 0.44, 1)",
            "slow": "0.8s cubic-bezier(0.165, 0.84, 0.44, 1)"
        }
    }
}
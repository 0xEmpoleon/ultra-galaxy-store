{
    "brand": "Somnia Network",
    "source": "https://somnia.network/",
    "description": "The fastest EVM-compatible layer one blockchain for a fully onchain world.",
    "colors": {
        "background-primary": "#FFFFFF",
        "background-secondary": "#F7F7F7",
        "background-dark": "#000000",
        "text-primary": "#000000",
        "text-secondary": "#787878",
        "text-muted": "#999999",
        "text-on-dark": "#FFFFFF",
        "text-on-dark-secondary": "#F7F7F7",
        "border": "#E5E5E5",
        "accent-purple": "#8E47FF",
        "accent-deep-purple": "#711AFF",
        "accent-pink": "#FF00D5",
        "accent-ice-blue": "#00D4FF",
        "accent-mint-green": "#61EA7D",
        "accent-acid-green": "#BBFF00",
        "accent-yellow": "#FBFF00",
        "accent-orange": "#FF7B00",
        "accent-deep-red": "#FF0000",
        "accent-cherry-red": "#FF006A"
    },
    "gradients": {
        "dream-aurora": "linear-gradient(225deg, #00D4FF 0%, #FF00D5 100%)",
        "dream-orion": "linear-gradient(225deg, #8E47FF 0%, #333AFF 100%)",
        "dream-celestine": "linear-gradient(225deg, #00D4FF 0%, #D6FF66 100%)",
        "dream-solaris": "linear-gradient(225deg, #FF00D5 0%, #FCFF66 100%)",
        "dream-phoenix": "linear-gradient(225deg, #FBFF00 0%, #FF006A 100%)"
    },
    "typography": {
        "font-primary": "'polySans', sans-serif",
        "body": {
            "size": "16px",
            "weight": "400",
            "lineHeight": "24px"
        },
        "h1": {
            "size": "clamp(56px, 4.5vw, 72px)",
            "weight": "600",
            "lineHeight": "100%"
        },
        "h2": {
            "size": "32px",
            "weight": "600",
            "lineHeight": "100%"
        },
        "h4": {
            "size": "20px",
            "weight": "600",
            "lineHeight": "100%"
        },
        "p": {
            "size": "20px",
            "weight": "400",
            "lineHeight": "100%"
        }
    },
    "spacing": {
        "radius": "0.75rem",
        "button-radius": "12px",
        "section-gap": "200px",
        "inner-gap": "24px"
    },
    "assets": {
        "favicon": "https://somnia.network/favicon.ico",
        "og-image": "https://somnia.network/images/og-image.png"
    }
}